# Sandbox image for LLM security scanner benchmark
# Provides a minimal environment for static analysis only (no execution)
FROM python:3.12-slim

# Install basic tools the LLM agent might need for code exploration
RUN apt-get update && apt-get install -y --no-install-recommends \
    grep \
    findutils \
    tree \
    file \
    && rm -rf /var/lib/apt/lists/*

# Create workspace directory (repos will be mounted here read-only)
RUN mkdir -p /workspace

# Non-root user for safety
RUN useradd -m -s /bin/bash auditor
USER auditor

WORKDIR /workspace

# No CMD - OpenHands controls execution
