{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Semgrep-compatible Security Findings",
  "description": "Output schema for LLM security scanner findings, compatible with Semgrep JSON format.",
  "type": "object",
  "required": ["version", "results"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version identifier",
      "const": "1.0.0"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "path", "start", "end", "extra"],
        "properties": {
          "check_id": {
            "type": "string",
            "description": "Rule identifier, e.g. 'python.security.injection.sql-injection'"
          },
          "path": {
            "type": "string",
            "description": "Relative file path from repo root, using forward slashes"
          },
          "start": {
            "type": "object",
            "required": ["line", "col"],
            "properties": {
              "line": { "type": "integer", "minimum": 1 },
              "col": { "type": "integer", "minimum": 1 },
              "offset": { "type": "integer", "minimum": 0 }
            }
          },
          "end": {
            "type": "object",
            "required": ["line", "col"],
            "properties": {
              "line": { "type": "integer", "minimum": 1 },
              "col": { "type": "integer", "minimum": 1 },
              "offset": { "type": "integer", "minimum": 0 }
            }
          },
          "extra": {
            "type": "object",
            "required": ["message", "metadata", "severity"],
            "properties": {
              "message": {
                "type": "string",
                "description": "Description of the vulnerability"
              },
              "severity": {
                "type": "string",
                "enum": ["ERROR", "WARNING", "INFO"],
                "description": "Severity level (ERROR=high/critical, WARNING=medium, INFO=low)"
              },
              "metadata": {
                "type": "object",
                "required": ["cwe", "confidence"],
                "properties": {
                  "cwe": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "CWE identifiers, e.g. ['CWE-89: SQL Injection']",
                    "minItems": 1
                  },
                  "confidence": {
                    "type": "string",
                    "enum": ["HIGH", "MEDIUM", "LOW"]
                  },
                  "category": {
                    "type": "string",
                    "description": "Category like 'security'"
                  },
                  "owasp": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
