% arxiv.sty — Minimal arXiv preprint style
% Based on https://github.com/kourgeorge/arxiv-style
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{arxiv}[2024/01/01 arXiv preprint style]

% Fonts
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}

% Page layout — two-column, compact margins
\RequirePackage[
  top=1in,
  bottom=1in,
  left=0.75in,
  right=0.75in,
  columnsep=0.25in
]{geometry}

% Line spacing
\RequirePackage{setspace}
\setstretch{1.0}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}
\titlespacing*{\section}{0pt}{2.5ex plus 1ex minus .2ex}{1.5ex plus .2ex}
\titlespacing*{\subsection}{0pt}{2.25ex plus 1ex minus .2ex}{1ex plus .2ex}

% Compact lists
\RequirePackage{enumitem}
\setlist{nosep,leftmargin=*}

% Header
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyhead[C]{\small\textit{Preprint. Under review.}}
\fancyfoot[C]{\thepage}

% Title formatting
\RequirePackage{titling}
\pretitle{\begin{center}\LARGE\bfseries}
\posttitle{\end{center}\vspace{0.5em}}
\preauthor{\begin{center}\large}
\postauthor{\end{center}}
\predate{\begin{center}\normalsize}
\postdate{\end{center}\vspace{-1em}}

% Captions
\RequirePackage[font=small,labelfont=bf]{caption}

% URLs
\RequirePackage{xcolor}
\definecolor{arxivblue}{HTML}{0055A4}
