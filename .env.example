# RealVuln LLM Benchmark — API Keys
# Copy this file to .env and fill in the keys you need.
# You only need keys for the providers you plan to use.

# ─── Required for Anthropic models (Claude Haiku, Sonnet, Opus) ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── Required for OpenAI models (GPT-4o, GPT-4o mini) ───
# Also used as a fallback for JSON repair when LLM output is malformed.
OPENAI_API_KEY=sk-proj-...

# ─── Required for Google models (Gemini 2.5 Pro, Gemini 3.1 Pro/Flash) ───
GEMINI_API_KEY=AIzaSy...

# ─── Required for Together AI models (DeepSeek V3, Llama 3.3, Qwen 3.5) ───
TOGETHER_API_KEY=...

# ─── Required for Moonshot models (Kimi K2.5) ───
MOONSHOT_API_KEY=sk-...

# ─── Required for Z.AI models (GLM-5) ───
ZAI_API_KEY=...

# ─── Optional: LiteLLM proxy (for MiniMax, Grok, and other providers) ───
# Only needed if you run models through a LiteLLM proxy server.
# See https://docs.litellm.ai/docs/simple_proxy for setup.
LITELLM_URL=http://localhost:4100
LITELLM_API_KEY=sk-...
