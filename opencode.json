{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "moonshot": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Moonshot",
      "options": {
        "baseURL": "https://api.moonshot.ai/v1",
        "apiKey": "{env:MOONSHOT_API_KEY}"
      },
      "models": {
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "attachment": true,
          "limit": {
            "context": 131072,
            "output": 16384
          }
        }
      }
    }
  }
}
